# ─────────────────────────────────────────────────────────────
# Myscapez Landing Page – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Resend API key – obtain from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives new lead notifications
# Must be a real inbox you own or manage
BUSINESS_EMAIL=admin@myscapez.com

# The "From" address used when sending emails
# Must match a verified domain in your Resend account
FROM_EMAIL=Myscapez <no-reply@myscapez.com.au>
